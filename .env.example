# ── Core ──────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/claudash
MONGODB_DB=claudash
PORT=3365

# ── Dashboard Auth ────────────────────────────────────────────────────────────
# Admin credentials for the dashboard UI login screen
CLAUDASH_ADMIN_USER=admin
CLAUDASH_ADMIN_PASS=change-me-to-a-strong-password

# JWT signing secret — generate once: python -c "import secrets; print(secrets.token_hex(32))"
# If omitted, a random secret is generated per-process (tokens invalidated on restart)
CLAUDASH_JWT_SECRET=

# JWT expiry in hours (default: 24)
CLAUDASH_JWT_EXPIRE_HOURS=24

# Legacy bearer token — still accepted for backward compat with hook agents
# Also used as ingest auth if ADMIN_PASS is not set
DASHBOARD_TOKEN=change-me-to-a-random-secret

# ── Privacy & Retention ───────────────────────────────────────────────────────
# Store what users type in prompts (UserPromptSubmit). Default: false (opt-in)
CLAUDASH_CAPTURE_PROMPTS=false
# Days to retain raw events and alert history. Default: 30
CLAUDASH_RETENTION_DAYS=30

# ── Session Reaper ────────────────────────────────────────────────────────────
# Hours without a hook event before a session is marked "stale". Default: 2
CLAUDASH_STALE_SESSION_HOURS=2
# How often the reaper runs in seconds. Default: 300 (5 min)
CLAUDASH_REAPER_INTERVAL_SEC=300

# ── Alerting — optional quick-setup ───────────────────────────────────────────
# These are env-var fallbacks; channels can also be fully configured via the UI.

# Slack incoming webhook URL
CLAUDASH_SLACK_WEBHOOK=

# Generic HTTP webhook
CLAUDASH_ALERT_WEBHOOK=
CLAUDASH_ALERT_WEBHOOK_SECRET=

# Email via SMTP
CLAUDASH_SMTP_HOST=
CLAUDASH_SMTP_PORT=587
CLAUDASH_SMTP_USER=
CLAUDASH_SMTP_PASS=
CLAUDASH_ALERT_FROM=
CLAUDASH_ALERT_TO=
